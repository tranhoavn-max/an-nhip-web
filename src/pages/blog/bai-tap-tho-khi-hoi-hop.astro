import { withBase } from '../../lib/site';

const sources = [
  {
    label: 'NHS (Anh): Breathing exercises for stress',
    href: 'https://www.nhs.uk/mental-health/self-help/guides-tools-and-activities/breathing-exercises-for-stress/',
  },
  {
    label: 'Harvard Health: Relaxation techniques: Breath control helps quell errant stress response',
    href: 'https://www.health.harvard.edu/mind-and-mood/relaxation-techniques-breath-control-helps-quell-errant-stress-response',
  },
  {
    label: 'WHO: Doing What Matters in Times of Stress (có bản dịch tiếng Việt)',
