---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase, PATHS, MEDICAL_DISCLAIMER_EN } from '../../lib/site';

const faq = [
  {
    q: 'Is An Nhịp free?',
    a: 'Yes. An Nhịp is a research project built as part of a master’s thesis. It is completely free, with no ads and no in-app purchases.',
  },
  {
    q: 'Is my data sent anywhere?',
    a: 'No. Everything is stored locally on your phone. The app has no server, asks for no account, and never sends any data out on its own. Your thought record text never leaves the device.',
  },
  {
    q: 'Does An Nhịp replace therapy?',
    a: 'No. An Nhịp is a self-practice tool based on cognitive behavioral therapy (CBT). It is not a medical device and does not replace diagnosis or treatment from a doctor or mental health professional.',
  },
  {
    q: 'Is the app on iOS or Google Play yet?',
    a: 'Right now An Nhịp is only available for Android, installed directly from an APK file. A Google Play version is being prepared. There are no plans for an iOS version yet. The app interface is currently in Vietnamese.',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'MobileApplication',
    name: 'An Nhịp',
    operatingSystem: 'Android',
    applicationCategory: 'HealthApplication',
    inLanguage: 'en',
    description:
      'An anxiety self-management app based on cognitive behavioral therapy (CBT): breathing exercises, the 5-4-3-2-1 grounding technique and a thought record. Data is stored locally on your device.',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'VND',
    },
    url: new URL(withBase(PATHS.en.download), Astro.site).href,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    inLanguage: 'en',
    mainEntity: faq.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    })),
  },
];
---

<BaseLayout
  lang="en"
  altPath="/"
  title="An Nhịp | CBT anxiety self-help app that keeps your data on your phone"
  description="Breathing exercises, 5-4-3-2-1 grounding and a CBT thought record to help you manage anxiety yourself. Free, no account, works offline with your data staying on your phone."
  jsonLd={jsonLd}
>
  <!-- ── Hero ─────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy fade-in">
        <h1>Heart racing, thoughts that will not stop?</h1>
        <p class="hero-sub muted">
          Breathing, grounding and a CBT thought record. It all runs right on
          your phone, with no connection needed.
        </p>
        <div class="hero-ctas">
          <a class="btn btn-primary" href={withBase(PATHS.en.download)}>Get the app</a>
          <a class="btn btn-secondary" href={withBase(PATHS.en.demo)}>Try the demo</a>
        </div>
      </div>
      <div class="hero-visual" aria-hidden="true">
        <svg viewBox="0 0 320 320" width="320" height="320" fill="none">
          <circle cx="160" cy="160" r="150" stroke="#5B9B8B" stroke-opacity="0.25" stroke-width="1.5"></circle>
          <circle class="breath-ring" cx="160" cy="160" r="112" stroke="#5B9B8B" stroke-opacity="0.55" stroke-width="2"></circle>
          <circle cx="160" cy="160" r="72" fill="#ECF2EF"></circle>
          <circle cx="160" cy="160" r="34" fill="#5B9B8B" opacity="0.5"></circle>
        </svg>
        <p class="hero-visual-caption muted">Breathe in for 4 seconds, out for 6 seconds</p>
      </div>
    </div>
  </section>

  <!-- ── Privacy pitch ────────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <h2 class="privacy-statement">
        Your data stays on your phone.
      </h2>
      <p class="measure muted">
        No server, no account, no tracking. What you write down while you are
        anxious is your own business, and the app is built so that stays true.
      </p>
      <div class="privacy-points">
        <div>
          <h3>Stored locally</h3>
          <p class="muted">
            Your data is kept on the device. The app never sends data anywhere
            on its own; a research file only leaves your phone when you
            actively export it yourself.
          </p>
        </div>
        <div>
          <h3>No sign-in</h3>
          <p class="muted">
            It collects no name, email, phone number or any other identifying
            information about you.
          </p>
        </div>
        <div>
          <h3>You can delete it all</h3>
          <p class="muted">
            Nothing is saved by default: each session is kept only when you tap
            Save. Delete all your data at any time from Settings.
          </p>
        </div>
      </div>
      <p><a href={withBase(PATHS.en.privacy)}>Read the full privacy policy</a></p>
    </div>
  </section>

  <!-- ── Three exercises (bento) ──────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <h2>Three exercises, ready the moment you need them</h2>
      <p class="measure muted">
        Each exercise is guided step by step in the app. Every input field can
        be left blank, and you decide whether to save anything.
      </p>
      <div class="bento">
        <article class="card bento-breathing">
          <svg class="bento-rings" viewBox="0 0 200 200" width="150" height="150" fill="none" aria-hidden="true">
            <circle cx="100" cy="100" r="92" stroke="#3D7367" stroke-opacity="0.2" stroke-width="1.5"></circle>
            <circle cx="100" cy="100" r="64" stroke="#3D7367" stroke-opacity="0.4" stroke-width="2"></circle>
            <circle cx="100" cy="100" r="34" fill="#3D7367" opacity="0.25"></circle>
          </svg>
          <h3>Breathing exercises</h3>
          <p class="muted">
            Box breathing (in 4 seconds, hold 4 seconds, out 4 seconds, hold 4
            seconds) or belly breathing (in 4 seconds, out 6 seconds). A slowly
            moving circle sets the pace for you, lasting 1, 3 or 5 minutes.
          </p>
        </article>
        <article class="card bento-grounding">
          <p class="grounding-numbers" aria-hidden="true">5 4 3 2 1</p>
          <h3>Grounding</h3>
          <p class="muted">
            The 5-4-3-2-1 technique: name 5 things you can see, 4 you can touch,
            3 sounds, 2 smells, 1 taste. It pulls your attention back to the
            present when your thoughts drift too far.
          </p>
        </article>
        <article class="card bento-thought">
          <h3>Thought record</h3>
          <p class="muted">
            Write down the situation and your thoughts across 6 CBT steps: from
            naming the emotion to finding a more balanced view. What you write
            never leaves your phone.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ── Live demo ────────────────────────────────────────────────── -->
  <section class="section">
    <div class="container demo-grid">
      <div class="demo-copy">
        <h2>Preview each screen</h2>
        <p class="muted">
          This is an interactive prototype of the app itself, running right in
          your browser. Tap through the exercises to get a feel for the pace
          before you install. The demo and the app interface are currently in
          Vietnamese.
        </p>
        <p>
          <a href={withBase(PATHS.en.demo)}>Open the demo on its own page, in a larger frame</a>
        </p>
      </div>
      <div class="phone-frame">
        <iframe
          src={withBase('/demo/an-nhip-prototype.html')}
          title="Interactive demo of the An Nhịp app"
          loading="lazy"
          width="375"
          height="720"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- ── FAQ ──────────────────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <h2>Frequently asked questions</h2>
      <div class="faq measure">
        {
          faq.map((item) => (
            <details>
              <summary>{item.q}</summary>
              <p class="muted">{item.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── Final CTA ────────────────────────────────────────────────── -->
  <section class="section">
    <div class="container closing">
      <h2>Next time your heart pounds, you have a place to come back to.</h2>
      <p>
        <a class="btn btn-primary" href={withBase(PATHS.en.download)}>Get the app</a>
      </p>
      <p class="note measure closing-note">
        An Nhịp is a free, non-commercial master’s thesis project. The app
        interface is currently in Vietnamese.
      </p>
      <p class="note note--medical measure closing-note">{MEDICAL_DISCLAIMER_EN}</p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: clamp(3.5rem, 8vw, 6rem);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(0, 1fr);
    gap: 3rem;
    align-items: center;
  }

  .hero-sub {
    font-size: 1.2rem;
    max-width: 32rem;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
  }

  .hero-visual {
    justify-self: center;
    text-align: center;
  }

  .hero-visual-caption {
    font-size: 0.9rem;
    margin-top: 0.75rem;
  }

  .privacy-statement {
    max-width: 26ch;
  }

  .privacy-points {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2.5rem;
    margin-block: 3rem 2rem;
  }

  .privacy-points h3 {
    font-size: 1.05rem;
    margin-bottom: 0.4em;
  }

  .privacy-points p {
    font-size: 0.97rem;
  }

  .bento {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    grid-template-rows: auto auto;
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .bento-breathing {
    grid-row: 1 / 3;
    background: var(--sage-soft);
    border-color: color-mix(in srgb, var(--sage) 22%, var(--line));
    display: flex;
    flex-direction: column;
    justify-content: end;
  }

  .bento-rings {
    margin-bottom: auto;
    padding-bottom: 1.5rem;
  }

  .bento-grounding .grounding-numbers {
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--sage-deco);
    margin: 0 0 0.75rem;
  }

  .bento-thought {
    background: #fdfcfa;
  }

  .demo-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 3rem;
    align-items: center;
  }

  .phone-frame {
    border: 1px solid var(--line);
    border-radius: 36px;
    padding: 12px;
    background: var(--surface);
    box-shadow: 0 2px 24px rgb(39 43 41 / 0.05);
    justify-self: center;
  }

  .phone-frame iframe {
    display: block;
    border: 0;
    border-radius: 26px;
    background: #fff;
  }

  .faq {
    margin-top: 1.5rem;
  }

  .faq details {
    border-bottom: 1px solid var(--line);
    padding-block: 1rem;
  }

  .faq summary {
    cursor: pointer;
    font-weight: 600;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .faq summary::-webkit-details-marker {
    display: none;
  }

  .faq summary::after {
    content: '+';
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--sage);
    flex: none;
  }

  .faq details[open] summary::after {
    content: '\2212';
  }

  .faq details p {
    margin: 0.75rem 0 0.25rem;
  }

  .closing {
    text-align: center;
  }

  .closing h2 {
    max-width: 24ch;
    margin-inline: auto;
  }

  .closing-note {
    margin: 2.5rem auto 0;
  }

  @media (max-width: 860px) {
    .hero-grid,
    .demo-grid {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      order: -1;
    }

    .hero-visual svg {
      width: 200px;
      height: 200px;
    }

    .privacy-points {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }

    .bento {
      grid-template-columns: 1fr;
    }

    .bento-breathing {
      grid-row: auto;
    }

    .phone-frame {
      justify-self: center;
      max-width: 100%;
    }

    .phone-frame iframe {
      width: min(375px, calc(100vw - 5rem));
    }
  }
</style>
