---
import { withBase, STRINGS, PATHS, type Lang } from '../lib/site';

interface Props {
  lang?: Lang;
}

const { lang = 'vi' } = Astro.props;
const t = STRINGS[lang];
const p = PATHS[lang];
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-about">
        <p class="footer-brand">An Nhịp</p>
        <p class="muted">{t.footerAbout}</p>
        <p class="muted footer-disclaimer">{t.disclaimer}</p>
      </div>
      <nav class="footer-nav" aria-label={t.footerNav.label}>
        <a href={withBase(p.home)}>{t.footerNav.home}</a>
        <a href={withBase(p.download)}>{t.footerNav.download}</a>
        <a href={withBase(p.blog)}>{t.footerNav.blog}</a>
        <a href={withBase(p.demo)}>{t.footerNav.demo}</a>
        <a href={withBase(p.privacy)}>{t.footerNav.privacy}</a>
      </nav>
    </div>
    <p class="note note--crisis footer-crisis">{t.crisis}</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--line);
    padding-block: 3.5rem;
    font-size: 0.95rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
    gap: 2.5rem;
  }

  .footer-brand {
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .footer-disclaimer {
    font-size: 0.88rem;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    align-items: start;
  }

  .footer-nav a {
    color: var(--ink);
    text-decoration: none;
  }

  .footer-nav a:hover {
    color: var(--sage);
  }

  .footer-crisis {
    margin-top: 2.5rem;
    margin-bottom: 0;
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
