---
import { withBase, STRINGS, PATHS, type Lang } from '../lib/site';

interface Props {
  lang?: Lang;
  /** In-site path of this page's counterpart in the other language. */
  altPath?: string;
}

const { lang = 'vi', altPath } = Astro.props;
const t = STRINGS[lang];
const p = PATHS[lang];
const altLang: Lang = lang === 'vi' ? 'en' : 'vi';
const switchHref = withBase(altPath ?? PATHS[altLang].home);
---

<header class="site-header">
  <div class="container header-row">
    <a class="brand" href={withBase(p.home)}>
      <svg
        class="brand-mark"
        width="26"
        height="26"
        viewBox="0 0 26 26"
        fill="none"
        aria-hidden="true"
      >
        <circle cx="13" cy="13" r="12" stroke="#3D7367" stroke-width="2"></circle>
        <circle cx="13" cy="13" r="6.5" fill="#5B9B8B" opacity="0.45"></circle>
      </svg>
      <span>An Nhịp</span>
    </a>
    <nav aria-label={t.nav.main}>
      <a href={withBase(p.blog)}>{t.nav.blog}</a>
      <a href={withBase(p.demo)}>{t.nav.demo}</a>
      <a class="lang-switch" href={switchHref} lang={altLang} aria-label={t.switchLabel}>
        {altLang.toUpperCase()}
      </a>
      <a class="btn btn-primary btn-nav" href={withBase(p.download)}>{t.nav.download}</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--line);
  }

  .header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-decoration: none;
  }

  .brand-mark {
    flex: none;
  }

  nav {
    display: flex;
    align-items: center;
    gap: clamp(0.8rem, 2.2vw, 1.6rem);
  }

  nav > a:not(.btn) {
    color: var(--ink);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.98rem;
  }

  nav > a:not(.btn):hover {
    color: var(--sage);
  }

  .lang-switch {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--ink-2);
    border: 1px solid var(--line);
    border-radius: var(--radius-ui);
    padding: 0.3rem 0.55rem;
  }

  .lang-switch:hover {
    border-color: var(--sage);
    color: var(--sage);
  }

  .btn-nav {
    padding: 0.5rem 1.05rem;
    font-size: 0.92rem;
  }
</style>
