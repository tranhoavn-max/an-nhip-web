---
import BaseLayout from './BaseLayout.astro';
import { withBase, STRINGS, PATHS, type Lang } from '../lib/site';

interface Source {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  heading: string;
  datePublished: string; // YYYY-MM-DD
  sources: Source[];
  lang?: Lang;
  /** In-site path of this article's counterpart in the other language. */
  altPath?: string;
}

const {
  title,
  description,
  heading,
  datePublished,
  sources,
  lang = 'vi',
  altPath,
} = Astro.props;

const t = STRINGS[lang];

const ui = {
  vi: {
    author: 'Nhóm phát triển An Nhịp',
    authorLd: 'Nhóm phát triển An Nhịp',
    noteIntro: 'Bài viết chia sẻ kỹ thuật tự thực hành, không phải tư vấn y khoa.',
    sources: 'Nguồn tham khảo',
    back: 'Xem các bài viết khác',
    condition: 'Lo âu (anxiety)',
  },
  en: {
    author: 'The An Nhịp team',
    authorLd: 'The An Nhịp team',
    noteIntro: 'This article shares self-help techniques and is not medical advice.',
    sources: 'Sources',
    back: 'Read other articles',
    condition: 'Anxiety',
  },
}[lang];

const displayDate =
  lang === 'vi'
    ? datePublished.split('-').reverse().join('/')
    : new Date(`${datePublished}T00:00:00Z`).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
        timeZone: 'UTC',
      });

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: heading,
    description,
    inLanguage: lang,
    datePublished,
    author: {
      '@type': 'Organization',
      name: ui.authorLd,
    },
    publisher: {
      '@type': 'Organization',
      name: 'An Nhịp',
    },
    mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).href,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'MedicalWebPage',
    name: heading,
    inLanguage: lang,
    about: {
      '@type': 'MedicalCondition',
      name: ui.condition,
    },
    lastReviewed: datePublished,
  },
];
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={jsonLd}
  ogType="article"
  lang={lang}
  altPath={altPath}
>
  <article class="section">
    <div class="container prose">
      <h1>{heading}</h1>
      <p class="muted article-meta">
        {ui.author} · {displayDate}
      </p>
      <p class="note note--medical">
        {ui.noteIntro}
        {t.disclaimer}
      </p>

      <slot />

      <h2>{ui.sources}</h2>
      <ul>
        {
          sources.map((s) => (
            <li>
              <a href={s.href} rel="noopener">
                {s.label}
              </a>
            </li>
          ))
        }
      </ul>

      <p class="note note--crisis">{t.crisis}</p>

      <p class="article-back">
        <a href={withBase(PATHS[lang].blog)}>{ui.back}</a>
      </p>
    </div>
  </article>
</BaseLayout>

<style>
  .article-meta {
    font-size: 0.92rem;
    margin-top: -0.5rem;
  }

  .note--medical {
    margin-block: 1.5rem 2.5rem;
  }

  .note--crisis {
    margin-top: 2.5rem;
  }

  .article-back {
    margin-top: 2.5rem;
  }
</style>
